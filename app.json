{
  "expo": {
    "name": "Wake Me App Alarm Clock",
    "slug": "wake-me-app",
    "scheme": "wake-me-app",
    "version": "3.0.0",
    "owner": "mtoplak",
    "newArchEnabled": true,
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "icon": "./assets/images/alarm-clock-icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#ffffff",
      "dark": {
        "backgroundColor": "#101212"
      },
      "image": "./assets/images/alarm-clock-splash.png",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mtoplak.wakemeapp",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "Wake Me uses the camera so you can scan a QR code to dismiss your alarm."
      }
    },
    "android": {
      "package": "com.mtoplak.wakemeapp",
      "googleServicesFile": "./google-services.json",
      "permissions": ["android.permission.CAMERA"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/alarm-clock-adaptive.png",
        "backgroundColor": "#ece9ff"
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Wake Me uses the camera so you can scan a QR code to dismiss your alarm."
        }
      ]
    ],
    "web": {
      "favicon": "./assets/images/alarm-clock-favicon.png"
    },
    "runtimeVersion": "1.0.0"
  }
}
