# Env variables
ENV=production
API_URL=https://example.com

# EXPO
EXPO_SLUG=react-native-boilerplate
EXPO_NAME="Wake Me App Alarm Clock"
EXPO_PROJECT_ID=18adc0d0-eb1d-11e9-8009-d524ed5cc4a7
EXPO_IOS_BUNDLE_IDENTIFIER=com.mtoplak.wakemeapp
EXPO_ANDROID_PACKAGE=com.mtoplak.wakemeapp

# Google Sign-In (OAuth 2.0)
#
# Get these from Google Cloud Console → APIs & Services → Credentials.
# Use the OAuth client whose application type matches the platform you're
# building for — Google rejects mixing types (e.g. Web Client on a native
# device returns "doesn't comply with OAuth 2.0 policy").
#
# - iOS:     Client type "iOS"      — also register its reverse-DNS scheme in
#                                     ios/.../Info.plist (CFBundleURLTypes).
# - Android: Client type "Android"  — also register your package + SHA-1 in
#                                     Google Cloud Console.
# - Web:     Client type "Web"      — used only when running on web; redirect
#                                     URI must be http(s).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Firebase web SDK config — not secret, safe to ship in client bundles.
# From Firebase Console → Project settings → Your apps → Web app.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# Optional — only set if you're using a non-default named Firestore database.
EXPO_PUBLIC_FIREBASE_DATABASE_ID=